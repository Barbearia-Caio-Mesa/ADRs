      "seed": 706547462,
      "version": 101,
      "versionNonce": 1877816390,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776537963845,
      "link": null,
      "locked": false,
      "text": "Camada de memória de alta velocidade.\nArmazena dados temporários para reduzir a\ncarga no banco de dados e acelerar\nrespostas.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Camada de memória de alta velocidade. Armazena dados temporários para reduzir a carga no banco de dados e acelerar respostas.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "PpILudFj6NuGiO0LxMyeL",
      "type": "text",
      "x": -1688.3842686932571,
      "y": 955.6142736320226,
      "width": 746.0277099609375,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0C",
      "roundness": null,
      "seed": 1659977286,
      "version": 117,
      "versionNonce": 937663258,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776537963845,
      "link": null,
      "locked": false,
      "text": "Banco de dados relacional gerenciado.\nArmazena de forma segura os dados\nestruturados de usuários, agendamentos e\nserviços.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Banco de dados relacional gerenciado. Armazena de forma segura os dados estruturados de usuários, agendamentos e serviços.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
