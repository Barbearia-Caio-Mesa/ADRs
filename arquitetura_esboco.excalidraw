      "isDeleted": false,
      "boundElements": [],
      "updated": 1776537963845,
      "link": null,
      "locked": false,
      "text": "Execução de código sob demanda (JOB).\nResponsável por tarefas de segundo plano,\ncomo o envio de notificações via Twilio.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Execução de código sob demanda (JOB). Responsável por tarefas de segundo plano, como o envio de notificações via Twilio.",
      "autoResize": false,
      "lineHeight": 1.25
