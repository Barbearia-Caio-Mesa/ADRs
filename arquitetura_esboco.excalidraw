      "isDeleted": false,
      "boundElements": [],
      "updated": 1776537963845,
      "link": null,
      "locked": false,
      "text": "Serviço serverless para rodar containers.\nHospeda o Front-end (site) e a API Java,\nescalando conforme a demanda.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Serviço serverless para rodar containers. Hospeda o Front-end (site) e a API Java, escalando conforme a demanda.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "71uWTPNtMR_cD_oEE9rPQ",
      "type": "text",
      "x": -1719.074899653538,
      "y": 630.1117791561755,
      "width": 757.3316650390625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
